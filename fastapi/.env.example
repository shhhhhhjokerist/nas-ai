# ── App ──
APP_NAME=NAS-AI
DEBUG=true

# ── Database (SQLite default) ──
DATABASE_URL=sqlite:///./test.db

# ── JWT (CHANGE THESE!) ──
JWT_SECRET_KEY=your-secret-key-at-least-32-bytes-long!!

# ── NAS Media root directory ──
MEDIA_DIR=F:/movies

# ── RAG / ChromaDB ──
CHROMA_DB_DIR=
EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVAL_TOP_K=5

# ── AI Agent (DeepSeek / OpenAI-compatible) ──
AGENT_MODEL=deepseek-v4-flash
AGENT_BASE_URL=https://api.deepseek.com/v1
AGENT_API_KEY=sk-your-api-key-here
AGENT_BASE_APP_URL=http://127.0.0.1:8000
